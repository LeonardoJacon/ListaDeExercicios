#include <stdio.h>
#include <string.h>

int main() {
    char palavras[3][30]; 
    int i;

    for(i = 0; i < 3; i++) {
        printf("Digite a palavra numero %d: ", i + 1);
        scanf("%s", palavras[i]);
    }

    printf("\nPalavras em ordem inversa:\n");

    for(i = 2; i >= 0; i--) {
        printf("%s\n", palavras[i]);
    }

    return 0;
}
