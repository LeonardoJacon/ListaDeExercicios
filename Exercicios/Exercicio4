#include <stdio.h>

int main() {
    int mat[3][3], id[3][3], res[3][3];
    int i, j, k;

    printf("Digite os elementos da matriz 3x3:\n");
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) {
            printf("Número [%d][%d]: ", i + 1, j + 1);
            scanf("%d", &mat[i][j]);
        }
    }
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) {
            if (i == j)
                id[i][j] = 1;
            else
                id[i][j] = 0;
        }
    }
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) {
            res[i][j] = 0; 
            for (k = 0; k < 3; k++) {
                res[i][j] += mat[i][k] * id[k][j];
            }
        }
    }
    printf("\nMatriz Inicial:\n");
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) printf("%d\t", mat[i][j]);
        printf("\n");
    }

    printf("\nMatriz Identidade:\n");
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) printf("%d\t", id[i][j]);
        printf("\n");
    }

    printf("\nMatriz resultante:\n");
    for (i = 0; i < 3; i++) {
        for (j = 0; j < 3; j++) printf("%d\t", res[i][j]);
        printf("\n");
    }

    return 0;
}
