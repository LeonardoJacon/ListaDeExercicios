#include <stdio.h>
#include <string.h>

int main() {
    int num[5][30]; 
    int i;

    for(i = 0; i < 5; i++) {
        printf("Digite o %dº numero: ", i + 1);
        scanf("%d", &num[i]);
    }

    printf("\nNúmeros em ordem inversa:\n");

    for(i = 4; i >= 0; i--) {
        printf("%d\n", num[i]);
    }

    return 0;
}
