#include <stdio.h>

int main() {
    int vetor[5];
    int *p = vetor; 
    int i;

    printf("Digite 5 números inteiros:\n");

    for (i = 0; i < 5; i++) {
        scanf("%d", (p + i));
    }

    printf("\n Dobrando cada valor lido:\n");

    for (i = 0; i < 5; i++) {
        printf("%d ", (*(p + i)) * 2);
    }
    printf("\n");

    return 0;
}
