#include <stdio.h>

int ordenar(int *a, int *b, int *c) {
    int temp;
    if (*a > *b) {
        temp = *a;
        *a = *b;
        *b = temp;
    }

    if (*a > *c) {
        temp = *a;
        *a = *c;
        *c = temp;
    }

    if (*b > *c) {
        temp = *b;
        *b = *c;
        *c = temp;
    }
    if (*a == *b && *b == *c) {
        return 1;
    }

    return 0;
}

int main() {
    int num, num2, num3;
    int resultado;

    printf("Digite tres valores inteiros:\n");
    scanf("%d %d %d", &num, &num2, &num3);

    resultado = ordenar(&num, &num2, &num3);

    printf("\nValores ordenados:\n");
    printf("Primeiro: %d\n", num);
    printf("Segundo: %d\n", num2);
    printf("Terceiro: %d\n", num3);

    if (resultado == 1) {
        printf("\nTodos os valores sao iguais.\n");
    } else {
        printf("\nExistem valores diferentes.\n");
    }

    return 0;
}	