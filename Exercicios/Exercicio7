#include <stdio.h>
#include <string.h>

typedef struct {
    char titulo[30];
    char autor[15];
    int ano;
} Livro;

int main() {
    Livro livros[5];
    int i;
    char procurar[30];
    for ( i = 0; i < 5; i++) {
        printf("\nLivro: %d", i+1);
        printf("\nDigite o Titulo do livro: ");
        scanf("%s", livros[i].titulo);
        printf("\nDigite o Autor do livro: ");
        scanf("%s", livros[i].autor);
        printf("\nDigite o Ano do livro: ");
        scanf("%d", &livros[i].ano);
    }
    printf("\nDigite o titulo para buscar: ");
    scanf("%s", procurar);
    for ( i = 0; i < 5; i++) {
        if (strcmp(procurar,livros[i].titulo)==0){
            printf("\n%s", livros[i].titulo);
            printf("\n%s", livros[i].autor);
            printf("\n%d", livros[i].ano);
        }
    }

    return 0;
}
