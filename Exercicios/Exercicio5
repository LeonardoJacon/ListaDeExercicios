#include <stdio.h>

int main() {
    int matriz[3][3];
    int vetor[3];
    int resultado[3];
    int i, j;

    printf("Digite os elementos da matriz 3x3 (inteiros):\n");
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            printf("Posição [%d][%d]: ", i+1, j+1);
            scanf("%d", &matriz[i][j]);
        }
    }

    printf("Digite os elementos do vetor:\n");
    for(i = 0; i < 3; i++) {
        printf("Elemento numero %d: ", i+1);
        scanf("%d", &vetor[i]);
    }

    for(j = 0; j < 3; j++) {
        resultado[j] = 0;
        for(i = 0; i < 3; i++) {
            resultado[j] += vetor[i] * matriz[i][j];
        }
    }

    printf("\nResultado da multiplicacao:\n");
    for(j = 0; j < 3; j++) {
        printf("%d ", resultado[j]);
    }

    return 0;
}
