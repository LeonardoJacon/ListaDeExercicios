#include <stdio.h>
#include <stdlib.h>

typedef struct No {
    char valor;
    struct No *prox;
} No;

typedef struct {
    No *topo;
} Pilha;

void inicializar(Pilha *p) {
    p->topo = NULL;
}

int isEmpty(Pilha *p) {
    return p->topo == NULL;
}

void push(Pilha *p, char c) {
    No *novo = (No*) malloc(sizeof(No));
    novo->valor = c;
    novo->prox = p->topo;
    p->topo = novo;
}

char pop(Pilha *p) {
    if (isEmpty(p)) return '\0';

    No *temp = p->topo;
    char valor = temp->valor;

    p->topo = temp->prox;
    free(temp);

    return valor;
}

int combina(char abre, char fecha) {
    return (abre == '(' && fecha == ')') ||
           (abre == '{' && fecha == '}') ||
           (abre == '[' && fecha == ']');
}

int main() {
    Pilha p;
    inicializar(&p);

    char expr[100];
    int i = 0;
    int valido = 1;

    printf("Digite a expressao: ");
    scanf("%s", expr);

    while (expr[i] != '\0') {
        char c = expr[i];

        if (c == '(' || c == '{' || c == '[') {
            push(&p, c);
        }
        else if (c == ')' || c == '}' || c == ']') {
            if (isEmpty(&p)) {
                valido = 0;
                break;
            }

            char topo = pop(&p);

            if (!combina(topo, c)) {
                valido = 0;
                break;
            }
        }

        i++;
    }

    if (!isEmpty(&p))
        valido = 0;

    if (valido)
        printf("Expressao VALIDA\n");
    else
        printf("Expressao INVALIDA\n");

    return 0;
}